<main class="auth-form__input-wrapper">
  <label class="auth-form__input-label" for="{{id}}">{{label}}</label>
  <input
    id="{{id}}"
    class="auth-form__input"
    name="{{name}}"
    type="{{type}}"
    value="{{value}}"
    autocomplete="off"
  />
  <span class="auth-form__input-error"></span>
</main>
