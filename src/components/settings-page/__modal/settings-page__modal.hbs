<div class="settings-modal">
  <div class="settings-modal__content">
    <h3 class="settings-modal__title">Загрузите файл</h3>
    <form
      class="settings-modal__form"
      id="settings-modal-avatar-form"
      novalidate
    >
      <div class="settings-modal__file-input">
        <label for="avatar-upload" class="settings-modal__file-link">
          Выбрать файл на компьютере
        </label>
        <input
          type="file"
          id="avatar-upload"
          name="avatar"
          accept="image/*"
          hidden
        />
        <div
          class="settings-modal__file-name"
          id="settings-modal-file-name"
          aria-live="polite"
        ></div>
      </div>
      <div
        class="settings-modal__message"
        id="settings-modal-message"
        aria-live="assertive"
      ></div>
      <button type="submit" class="settings-modal__submit">
        Поменять
      </button>
    </form>
    <button
      type="button"
      class="settings-modal__close"
      data-action="close-modal"
      aria-label="Закрыть"
    >
      ✕
    </button>
  </div>
</div>