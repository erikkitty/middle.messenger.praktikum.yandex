<div class="settings-change-data">
  <button
    type="button"
    class="settings-change-data__back"
    data-action="back-to-profile"
  >
    К профилю
  </button>
  <form
    class="settings-change-data__form"
    id="settings-change-data-form"
    novalidate
  >
    <div class="settings-change-data__row">
      <label
        class="settings-change-data__label"
        for="change-data-email"
      >Почта</label>
      <input
        type="text"
        id="change-data-email"
        name="email"
        class="settings-change-data__input"
        data-field="email"
      />
    </div>
    <div class="settings-change-data__row">
      <label
        class="settings-change-data__label"
        for="change-data-login"
      >Логин</label>
      <input
        type="text"
        id="change-data-login"
        name="login"
        class="settings-change-data__input"
        data-field="login"
      />
    </div>
    <div class="settings-change-data__row">
      <label
        class="settings-change-data__label"
        for="change-data-first_name"
      >Имя</label>
      <input
        type="text"
        id="change-data-first_name"
        name="first_name"
        class="settings-change-data__input"
        data-field="first_name"
      />
    </div>
    <div class="settings-change-data__row">
      <label
        class="settings-change-data__label"
        for="change-data-second_name"
      >Фамилия</label>
      <input
        type="text"
        id="change-data-second_name"
        name="second_name"
        class="settings-change-data__input"
        data-field="second_name"
      />
    </div>
    <div class="settings-change-data__row">
      <label
        class="settings-change-data__label"
        for="change-data-display_name"
      >Имя в чате</label>
      <input
        type="text"
        id="change-data-display_name"
        name="display_name"
        class="settings-change-data__input"
        data-field="display_name"
      />
    </div>
    <div class="settings-change-data__row">
      <label
        class="settings-change-data__label"
        for="change-data-phone"
      >Телефон</label>
      <input
        type="text"
        id="change-data-phone"
        name="phone"
        class="settings-change-data__input"
        data-field="phone"
      />
    </div>
    <div class="settings-change-data__actions">
      <button
        type="submit"
        class="settings-change-data__submit"
      >Сохранить</button>
      <button
        type="button"
        class="settings-change-data__cancel"
        data-action="cancel-edit-data"
      >Отмена</button>
    </div>
  </form>
</div>