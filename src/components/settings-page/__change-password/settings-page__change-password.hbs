<div class="settings-change-password">
  <button type="button" class="settings-change-password__back" data-action="back-to-profile">
    ← К профилю
  </button>
  <form class="settings-change-password__form">
    <div class="settings-change-password__field">
      <label class="settings-change-password__label" for="old-password">
        Старый пароль
      </label>
      <input
        type="password"
        id="old-password"
        name="old_password"
        class="settings-change-password__input"
        autocomplete="current-password"
      />
      <span class="settings-change-password__error"></span>
    </div>

    <div class="settings-change-password__field">
      <label class="settings-change-password__label" for="new-password">
        Новый пароль
      </label>
      <input
        type="password"
        id="new-password"
        name="new_password"
        class="settings-change-password__input"
        autocomplete="new-password"
      />
      <span class="settings-change-password__error"></span>
    </div>

    <div class="settings-change-password__field">
      <label class="settings-change-password__label" for="confirm-password">
        Повторите новый пароль
      </label>
      <input
        type="password"
        id="confirm-password"
        name="confirm_password"
        class="settings-change-password__input"
        autocomplete="new-password"
      />
      <span class="settings-change-password__error"></span>
    </div>

    <button type="submit" class="settings-change-password__submit">
      Сохранить
    </button>
  </form>
</div>